---
import Layout from '../../layouts/Layout.astro';

const projects = [
  {
    slug: 'daytrade-assistant',
    name: 'DayTrade Assistant',
    tagline: 'Algorithmic swing trade screener with live Schwab API integration',
    tags: ['Python', 'Schwab API', 'SQLite', 'TradingView'],
    accent: '#00d9ff',
    icon: '📈',
    stat: 'S&P 500 + Nasdaq 100',
    bg: 'linear-gradient(135deg, #0a1128 0%, #0c2340 50%, #0a3060 100%)',
  },
  {
    slug: 'wrt-advisory',
    name: 'WRT Advisory',
    tagline: 'Independent business valuation and M&A advisory firm',
    tags: ['Financial Modeling', 'DCF', 'M&A', 'Python'],
    accent: '#818cf8',
    icon: '🏦',
    stat: 'Minneapolis · Founded 2026',
    bg: 'linear-gradient(135deg, #0a1128 0%, #1a1040 50%, #2a1060 100%)',
  },
  {
    slug: 'ai-sales-trainer',
    name: 'AI Sales Trainer',
    tagline: 'Real-time AI coaching for high-ticket remote sellers',
    tags: ['Claude API', 'Electron', 'Twilio', 'Deepgram'],
    accent: '#34d399',
    icon: '🎙️',
    stat: 'Phase 1 complete',
    bg: 'linear-gradient(135deg, #0a1128 0%, #0a2820 50%, #0a3828 100%)',
  },
  {
    slug: 'cortex',
    name: 'Cortex',
    tagline: 'AI-powered desktop app for productivity and deep work',
    tags: ['Electron', 'React', 'TypeScript', 'Claude API'],
    accent: '#fb923c',
    icon: '🧠',
    stat: 'Phase 1 live',
    bg: 'linear-gradient(135deg, #0a1128 0%, #201010 50%, #381808 100%)',
  },
  {
    slug: 'terminal-intelligence',
    name: 'Terminal Intelligence',
    tagline: 'B2B newsletter for aviation tech vendors selling into ULCCs',
    tags: ['Aviation', 'B2B', 'Market Research', 'HTML'],
    accent: '#f472b6',
    icon: '✈️',
    stat: 'Live on GitHub',
    bg: 'linear-gradient(135deg, #0a1128 0%, #200a28 50%, #300838 100%)',
  },
];
---

<Layout title="Projects — Rob DeGonda">
  <main>
    <section class="projects-hero">
      <div class="container">
        <p class="section-label fade-in">Work</p>
        <h1 class="fade-in">Projects</h1>
        <p class="hero-sub fade-in">Five simultaneous builds across fintech, AI, and aviation. Each one solves a real problem.</p>
      </div>
    </section>

    <section class="projects-list">
      <div class="container">
        {projects.map((p, i) => (
          <a href={`/projects/${p.slug}`} class="project-row fade-in" style={`--delay:${i*0.07}s; --accent:${p.accent}; background:${p.bg};`}>
            <div class="row-left">
              <span class="row-icon">{p.icon}</span>
              <div class="row-info">
                <h2 class="row-name">{p.name}</h2>
                <p class="row-tagline">{p.tagline}</p>
                <div class="row-tags">
                  {p.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              </div>
            </div>
            <div class="row-right">
              <span class="row-stat">{p.stat}</span>
              <span class="row-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .projects-hero {
    padding: 80px 0 48px;
  }
  h1 {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }
  .hero-sub {
    font-size: 17px;
    color: var(--text-muted);
    margin-bottom: 0;
  }
  .projects-list { padding: 0 0 100px; }
  .project-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 28px 32px;
    border-radius: 14px;
    border: 1px solid var(--border);
    margin-bottom: 16px;
    text-decoration: none;
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    transition-delay: var(--delay);
  }
  .project-row:hover {
    border-color: var(--accent);
    transform: translateX(4px);
    box-shadow: 0 4px 24px rgba(0,0,0,0.3);
    text-decoration: none;
  }
  .row-left { display: flex; align-items: center; gap: 20px; }
  .row-icon { font-size: 32px; flex-shrink: 0; }
  .row-name {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
  }
  .row-tagline {
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 10px;
  }
  .row-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--border);
    padding: 3px 10px;
    border-radius: 6px;
  }
  .row-right {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }
  .row-stat {
    font-size: 12px;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .row-arrow {
    font-size: 20px;
    color: var(--accent);
    transition: transform 0.2s;
  }
  .project-row:hover .row-arrow { transform: translateX(4px); }

  @media (max-width: 640px) {
    .project-row { flex-direction: column; align-items: flex-start; }
    .row-right { width: 100%; justify-content: space-between; }
  }
</style>
