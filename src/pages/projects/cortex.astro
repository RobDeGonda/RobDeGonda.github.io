---
import Layout from '../../layouts/Layout.astro';
import FileTree from '../../components/FileTree.astro';

const files = [
  { name: 'electron', type: 'folder', children: [
    { name: 'main.ts', type: 'file' },
    { name: 'preload.ts', type: 'file' },
  ]},
  { name: 'renderer', type: 'folder', children: [
    { name: 'src/App.tsx', type: 'file' },
    { name: 'src/components/ArcReactor.tsx', type: 'file' },
    { name: 'src/components/GapAnalysis.tsx', type: 'file' },
    { name: 'src/components/GoalTracker.tsx', type: 'file' },
    { name: 'src/components/HUDPanel.tsx', type: 'file' },
    { name: 'src/components/Metrics.tsx', type: 'file' },
  ]},
  { name: 'dist', type: 'folder', children: [
    { name: 'electron/main.js', type: 'file' },
    { name: 'shared/constants.js', type: 'file' },
  ]},
  { name: 'package.json', type: 'file' },
  { name: 'CLAUDE.md', type: 'file' },
  { name: '.env.example', type: 'file' },
];
---

<Layout title="Cortex — Rob DeGonda">
  <main>
    <div class="project-hero">
      <div class="neural-bg" id="neural-bg"></div>
      <div class="hero-overlay"></div>
      <div class="container hero-content">
        <a href="/projects" class="back-link">← Projects</a>
        <div class="project-icon">🧠</div>
        <h1>Cortex</h1>
        <p class="project-tagline">AI-powered desktop app for deep work, goal tracking, and personal productivity</p>
        <div class="project-meta">
          <span class="meta-tag">Electron</span>
          <span class="meta-tag">React</span>
          <span class="meta-tag">TypeScript</span>
          <span class="meta-tag">Claude API</span>
          <span class="meta-tag">Node.js</span>
        </div>
      </div>
    </div>

    <div class="container project-body">
      <div class="project-grid">
        <div class="project-main">
          <h2>What it is</h2>
          <p>Cortex is a cross-platform desktop application built on Electron and React. The core idea: a persistent productivity layer that lives on your desktop, tracks your goals, surfaces gaps in your progress, and eventually talks to you. It's designed for people running multiple high-stakes projects simultaneously.</p>
          <p>Phase 1 is live — a session dashboard (ArcReactor), goal tracker, and gap analysis engine that identifies where you're falling behind and surfaces the most important next action. The UI is dark, minimal, and intentionally sparse. It doesn't fight for your attention; it responds to it.</p>
          <p>Phase 2 adds a voice layer: a Fastify server connecting Twilio, Deepgram, Claude, and ElevenLabs into a voice-driven interaction model. You speak to Cortex; it responds, logs, and adjusts. Think of it as a real-time advisor that knows your full context.</p>

          <h2>Phase roadmap</h2>
          <div class="phases">
            <div class="phase complete">
              <span class="phase-badge">Phase 1 ✓</span>
              <h3>Desktop dashboard</h3>
              <p>Electron + React app. Session dashboard, goal tracker, gap analysis. Renderer builds clean.</p>
            </div>
            <div class="phase active">
              <span class="phase-badge">Phase 2 →</span>
              <h3>Voice server</h3>
              <p>Fastify + Twilio + Deepgram + Claude + ElevenLabs. Voice-driven interaction. Full architecture designed.</p>
            </div>
            <div class="phase future">
              <span class="phase-badge">Phase 3</span>
              <h3>Intelligence layer</h3>
              <p>Calendar integration, habit tracking, proactive nudges. Cortex knows your schedule, not just your goals.</p>
            </div>
          </div>
        </div>

        <div class="project-sidebar">
          <FileTree repoName="Cortex" files={files} />
          <div class="sidebar-stats">
            <div class="stat-row"><span>Phase 1</span><strong class="status-live">Live</strong></div>
            <div class="stat-row"><span>Phase 2</span><strong class="status-building">In development</strong></div>
            <div class="stat-row"><span>Platform</span><strong>macOS · Windows</strong></div>
            <div class="stat-row"><span>Stack</span><strong>Electron + React + Claude</strong></div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const bg = document.getElementById('neural-bg');
  if (bg) {
    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('width', '100%');
    svg.setAttribute('height', '100%');
    svg.style.position = 'absolute';
    svg.style.inset = '0';
    svg.style.opacity = '0.25';

    const W = window.innerWidth, H = 340;
    const nodes: {x:number,y:number}[] = [];
    for (let i = 0; i < 30; i++) {
      nodes.push({ x: Math.random() * W, y: Math.random() * H });
    }

    nodes.forEach((n, i) => {
      nodes.forEach((m, j) => {
        if (i >= j) return;
        const d = Math.hypot(n.x - m.x, n.y - m.y);
        if (d < 180) {
          const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          line.setAttribute('x1', String(n.x));
          line.setAttribute('y1', String(n.y));
          line.setAttribute('x2', String(m.x));
          line.setAttribute('y2', String(m.y));
          line.setAttribute('stroke', '#fb923c');
          line.setAttribute('stroke-width', '0.5');
          svg.appendChild(line);
        }
      });
      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', String(n.x));
      circle.setAttribute('cy', String(n.y));
      circle.setAttribute('r', '3');
      circle.setAttribute('fill', '#fb923c');
      svg.appendChild(circle);
    });

    bg.appendChild(svg);
  }
</script>

<style>
  .project-hero {
    position: relative;
    height: 340px;
    overflow: hidden;
    background: linear-gradient(135deg, #0a1128, #201010, #2a1408);
    display: flex;
    align-items: flex-end;
  }
  .neural-bg { position: absolute; inset: 0; }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10,17,40,0.2) 0%, rgba(10,17,40,0.7) 100%);
  }
  .hero-content { position: relative; z-index: 2; padding-bottom: 40px; }
  .back-link { display: inline-block; font-size: 13px; color: var(--text-muted); margin-bottom: 16px; transition: color 0.2s; }
  .back-link:hover { color: var(--text); text-decoration: none; }
  .project-icon { font-size: 36px; margin-bottom: 12px; }
  h1 { font-size: clamp(32px, 5vw, 52px); font-weight: 800; letter-spacing: -0.03em; margin-bottom: 12px; }
  .project-tagline { font-size: 17px; color: var(--text-muted); margin-bottom: 16px; max-width: 540px; }
  .project-meta { display: flex; flex-wrap: wrap; gap: 8px; }
  .meta-tag { font-size: 12px; font-weight: 600; color: #fb923c; background: rgba(251,146,60,0.1); border: 1px solid rgba(251,146,60,0.25); padding: 4px 12px; border-radius: 100px; }

  .project-body { padding: 48px 0 100px; }
  .project-grid { display: grid; grid-template-columns: 1fr 400px; gap: 48px; align-items: start; }
  .project-main h2 { font-size: 20px; font-weight: 700; margin: 0 0 16px; }
  .project-main h2:not(:first-child) { margin-top: 40px; }
  .project-main > p { font-size: 15px; color: var(--text-muted); line-height: 1.75; margin-bottom: 16px; }

  .phases { display: flex; flex-direction: column; gap: 12px; }
  .phase { padding: 20px; border-radius: 10px; border: 1px solid var(--border); }
  .phase.complete { border-color: rgba(52,211,153,0.3); background: rgba(52,211,153,0.03); }
  .phase.active { border-color: rgba(251,146,60,0.4); background: rgba(251,146,60,0.04); }
  .phase.future { background: var(--bg-card); }
  .phase-badge { font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px; display: block; }
  .phase.complete .phase-badge { color: #34d399; }
  .phase.active .phase-badge { color: #fb923c; }
  .phase.future .phase-badge { color: var(--text-muted); }
  .phase h3 { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
  .phase p { font-size: 13px; color: var(--text-muted); margin: 0; line-height: 1.6; }

  .project-sidebar { display: flex; flex-direction: column; gap: 16px; }
  .sidebar-stats { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  .stat-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 13px; }
  .stat-row:last-child { border-bottom: none; }
  .stat-row span { color: var(--text-muted); }
  .stat-row strong { color: var(--text); }
  .status-live { color: #34d399 !important; }
  .status-building { color: #fb923c !important; }
  @media (max-width: 900px) { .project-grid { grid-template-columns: 1fr; } }
</style>
