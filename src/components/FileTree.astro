---
interface FileNode {
  name: string;
  type: 'file' | 'folder';
  children?: FileNode[];
}
interface Props {
  repoName: string;
  repoUrl?: string;
  files: FileNode[];
  description?: string;
}
const { repoName, repoUrl, files, description } = Astro.props;

function getIcon(name: string, type: string) {
  if (type === 'folder') return '📁';
  const ext = name.split('.').pop()?.toLowerCase();
  const icons: Record<string, string> = {
    py: '🐍', js: '📜', ts: '📘', tsx: '📘', jsx: '📜',
    md: '📄', json: '⚙️', html: '🌐', css: '🎨',
    astro: '🚀', txt: '📄', yml: '⚙️', yaml: '⚙️',
    env: '🔒', gitignore: '🚫', svg: '🖼️', png: '🖼️',
    pdf: '📋', docx: '📋', sql: '🗄️', sh: '💻',
  };
  return icons[ext || ''] || '📄';
}
---

<div class="filetree">
  <div class="filetree-header">
    <div class="filetree-repo">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="opacity:0.6">
        <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Z"/>
      </svg>
      <span class="repo-name">{repoName}</span>
      {description && <span class="repo-desc">{description}</span>}
    </div>
    {repoUrl && (
      <a href={repoUrl} target="_blank" rel="noopener" class="view-github">
        View on GitHub ↗
      </a>
    )}
  </div>
  <div class="filetree-body">
    {files.map(node => (
      <div class={`tree-item ${node.type}`}>
        <span class="tree-icon">{getIcon(node.name, node.type)}</span>
        <span class="tree-name">{node.name}</span>
        {node.children && (
          <div class="tree-children">
            {node.children.map(child => (
              <div class={`tree-item ${child.type} nested`}>
                <span class="tree-icon">{getIcon(child.name, child.type)}</span>
                <span class="tree-name">{child.name}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<style>
  .filetree {
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 10px;
    overflow: hidden;
    font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;
    font-size: 13px;
  }

  .filetree-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: #161b22;
    border-bottom: 1px solid #30363d;
    flex-wrap: wrap;
    gap: 8px;
  }

  .filetree-repo {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #58a6ff;
  }

  .repo-name {
    font-weight: 600;
    font-size: 14px;
  }

  .repo-desc {
    color: #8b949e;
    font-size: 12px;
    font-family: system-ui, sans-serif;
  }

  .view-github {
    font-size: 12px;
    font-weight: 600;
    color: #58a6ff;
    font-family: system-ui, sans-serif;
    transition: opacity 0.2s;
  }
  .view-github:hover { opacity: 0.7; text-decoration: none; }

  .filetree-body {
    padding: 8px 0;
    max-height: 420px;
    overflow-y: auto;
  }

  .tree-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 16px;
    transition: background 0.15s;
    cursor: default;
  }
  .tree-item:hover { background: #161b22; }

  .tree-icon { font-size: 14px; flex-shrink: 0; }

  .tree-name {
    color: #c9d1d9;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tree-item.folder > .tree-name { color: #58a6ff; font-weight: 500; }

  .tree-children {
    width: 100%;
    margin-top: 2px;
  }

  .tree-item.nested {
    padding-left: 40px;
  }

  .filetree-body::-webkit-scrollbar { width: 6px; }
  .filetree-body::-webkit-scrollbar-track { background: transparent; }
  .filetree-body::-webkit-scrollbar-thumb { background: #30363d; border-radius: 3px; }
</style>
